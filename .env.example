# =============================================================================
# macro-invest-agent-platform  —  environment variable template
# =============================================================================
# Copy this file to .env and fill in values for your local environment.
# The .env file is gitignored and must never be committed.
#
# Variable naming conventions:
#   APP_*        → application-level settings
#   DATABASE_*   → PostgreSQL connection settings
#   MINIO_*      → MinIO / S3-compatible object store settings
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Running environment. Valid values: local | test | staging | production
APP_ENV=local

# Log level. Valid values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# Set to "true" to emit pretty-printed (human-readable) logs instead of JSON.
LOG_PRETTY=true

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------

# Full connection URL used by SQLAlchemy / Alembic.
# Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+psycopg://macro_user:macro_pass@localhost:5432/macro_db

POSTGRES_USER=macro_user
POSTGRES_PASSWORD=macro_pass
POSTGRES_DB=macro_db

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object store)
# ---------------------------------------------------------------------------

# MinIO API endpoint (used by boto3 / aiobotocore).
MINIO_ENDPOINT=http://localhost:9000

# Root (admin) credentials — for local development only.
# Never use these values in production.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Default bucket for raw macro data artefacts.
MINIO_BUCKET_RAW=macro-raw

# ---------------------------------------------------------------------------
# Aleph-One — Docker image (production VPS only)
# ---------------------------------------------------------------------------

# Docker Hub image path pushed by GitHub Actions CD.
# Format: <DOCKERHUB_USERNAME>/aleph-api
DOCKER_IMAGE=alstjd9615/aleph-api
IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Aleph-One — LLM provider (src/config.py)
# ---------------------------------------------------------------------------

# ENV_MODE=PRODUCTION forces Groq (requires GROQ_API_KEY). Default: LOCAL
# LOCAL: uses Groq if GROQ_API_KEY is set, falls back to Ollama otherwise.
ENV_MODE=LOCAL

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Optional: Ollama fallback (LOCAL mode only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ---------------------------------------------------------------------------
# Aleph-One — Milvus Lite (embedded vector store)
# ---------------------------------------------------------------------------

# Path to the Milvus Lite database file (created automatically on first run).
MILVUS_LITE_PATH=./data/milvus_lite.db

# ---------------------------------------------------------------------------
# Aleph-One — CORS (production)
# ---------------------------------------------------------------------------

# Comma-separated list of additional allowed origins injected at runtime.
# Example: CORS_ALLOWED_ORIGINS=https://aleph-one.vercel.app,https://custom.domain.com
CORS_ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# Aleph-One — Macro data (src/database.py)
# ---------------------------------------------------------------------------

# Optional: FRED (Federal Reserve Economic Data) API key.
# Free registration: https://fred.stlouisfed.org/docs/api/api_key.html
# When set: fetches authoritative CPI, GDP, Fed Funds Rate, Unemployment Rate.
# When absent: falls back to yfinance real-time proxies (T10Y, T3M, VIX).
FRED_API_KEY=

# Optional: BLS (Bureau of Labor Statistics) Data API key.
# Free registration: https://www.bls.gov/developers/api_signature_v2.htm
# Without key: 25 requests/day (public API). With key: 500 requests/day.
# Provides US_CPI_BLS (CPI-U) and US_UNRATE_BLS (civilian unemployment rate).
# When absent: BLS source is skipped (FRED / yfinance still cover US indicators).
BLS_API_KEY=

# Optional: 한국은행 ECOS Open API key for Korean macro data.
# Free registration: https://ecos.bok.or.kr/ → API신청 menu
# Provides KR_BASE_RATE (기준금리) and KR_CPI (소비자물가지수).
# When absent: KR macro series are not collected.
BOK_API_KEY=

# Note: ECB Data Portal (EU_HICP) requires no API key — collected automatically.

# Optional: KOFIA (금융투자협회) OpenAPI key for fund NAV ingestion.
# SCAFFOLD ONLY — the real KOFIA endpoint contract is not yet verified
# (see fetch_fund_nav() / _fetch_kofia_fund_nav() in src/database.py).
# Setting this alone does nothing until FUND_NAV_TARGETS is populated and
# the adapter stub is implemented against the real KOFIA API guide.
KOFIA_API_KEY=

# ---------------------------------------------------------------------------
# Phase A-1 — Multi-source macro ingestion
# ---------------------------------------------------------------------------

# Optional: Alpha Vantage API key for GDP + Interest Rate data.
# Free registration: https://www.alphavantage.co/support/#api-key
# Free tier limits: 25 requests/day, 5 requests/minute.
# When absent: Alpha Vantage source is skipped (graceful degradation).
ALPHA_VANTAGE_API_KEY=

# Optional: Supabase PostgreSQL connection string for feature snapshot storage.
# Supabase project: Settings > Database > Connection string > URI
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# When absent: feature snapshots are not persisted to Supabase.
SUPABASE_DB_URL=

# ---------------------------------------------------------------------------
# Market data adapters (Level 2-1 — optional, coexist with yfinance)
# ---------------------------------------------------------------------------

# Alpaca Markets — US stocks / ETFs (AAPL, MSFT, TSLA, QQQ, BND, GLD, …)
# Free tier: IEX feed data, no subscription needed.
# Register at: https://app.alpaca.markets → API Keys (Paper trading is enough for data)
# When set: replaces yfinance as primary source for US-listed tickers.
# When absent: yfinance is used for all tickers (no degradation).
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Finnhub — real-time US quote supplement (current-day OHLCV snapshot)
# Free tier: 60 req/min, US exchanges only (Korean stocks need premium plan).
# Register at: https://finnhub.io → Dashboard → API Keys
# When set: provides a real-time today snapshot to supplement historical bars.
# When absent: only historical bars from Alpaca / yfinance are used.
FINNHUB_API_KEY=

# KIS Developers API — Korean stocks (005930, 000660, etc.)
# Requires KIS (한국투자증권) account + developer API key registration.
# Register at: https://apiportal.koreainvestment.com/
# STUB: the real adapter is not yet implemented. Setting these keys
# does nothing until fetch_kis_bars() in src/adapters.py is completed.
KIS_APP_KEY=
KIS_APP_SECRET=

# ---------------------------------------------------------------------------
# Observability (optional — all no-op when unset)
# ---------------------------------------------------------------------------

# Sentry DSN for automatic error capture on the backend.
# Free tier: 5,000 errors/month. https://sentry.io → create project → Settings > Client Keys
# When absent: no error capture (local/dev is fine without it).
SENTRY_DSN=

# Slack Incoming Webhook URL for critical collector failure alerts.
# Create at: your Slack workspace → Apps → Incoming Webhooks
# Fires when live_collector fails 5 consecutive cycles or macro_collector fails once.
# When absent: failures are logged only (no Slack notification).
SLACK_WEBHOOK_URL=
