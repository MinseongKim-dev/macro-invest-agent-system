# ── Aleph-One Self-Healing Watchdog — Environment Template ──────────────────
# Copy this file to .env.watchdog and fill in the values marked <REQUIRED>.
# NEVER commit the real .env.watchdog to git.

# ── Health Check ─────────────────────────────────────────────────────────────
HEALTH_URL=http://localhost:8001/health
CHECK_INTERVAL_SECONDS=60
FAILURE_THRESHOLD=3
HEALTH_TIMEOUT_SECONDS=10

# ── Heal Cooldown ─────────────────────────────────────────────────────────────
COOLDOWN_MINUTES=15

# ── Docker / Deploy ───────────────────────────────────────────────────────────
DOCKER_COMPOSE_FILE=/opt/aleph-one/docker-compose.prod.yml
DOCKER_SERVICE_NAME=aleph-api
DEPLOY_PATH=/opt/aleph-one
LOG_TAIL_LINES=150

# ── Claude API ────────────────────────────────────────────────────────────────
# <REQUIRED> — Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-7

# ── GitHub ────────────────────────────────────────────────────────────────────
# <REQUIRED> — Fine-grained PAT with Contents: Read & Write on target repo
GITHUB_TOKEN=github_pat_...
# <REQUIRED> — Format: owner/repo  e.g. minseongkim-dev/macro-invest-agent-system
GITHUB_REPO=minseongkim-dev/macro-invest-agent-system
GITHUB_BRANCH=main

# ── Source Files to Watch ────────────────────────────────────────────────────
TARGET_SOURCE_FILES=src/main.py,src/database.py,src/engines.py
