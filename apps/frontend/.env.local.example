# =============================================================================
# Aleph-One Frontend — environment variable template
# =============================================================================
# Copy this file to .env.local and fill in values for your environment.
# .env.local is gitignored and must never be committed.

# ---------------------------------------------------------------------------
# Server-side (Next.js Route Handlers) — never exposed to the browser
# ---------------------------------------------------------------------------

# Base URL of the Aleph-One FastAPI backend reachable from the Next.js server.
# Docker Compose (local): http://aleph-api:8001
# Vercel + VPS (production): https://api.your-domain.com
ALEPH_API_URL=http://aleph-api:8001

# ---------------------------------------------------------------------------
# Client-side (browser) — prefix with NEXT_PUBLIC_ to expose
# ---------------------------------------------------------------------------

# Public base URL of the API, used for any direct browser fetches.
# Leave empty to rely on same-origin Next.js Route Handler proxies (recommended).
NEXT_PUBLIC_API_URL=

# ---------------------------------------------------------------------------
# Supabase Auth (optional — activate when opening to external users)
# ---------------------------------------------------------------------------
# Get these from: https://supabase.com → your project → Settings → API
# Free tier: up to 50,000 MAUs. Leave blank to skip auth enforcement.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
